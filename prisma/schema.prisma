generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  currency  String   @default("COP")
  plan      Plan     @default(FREE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  accounts     Account[]
  categories   Category[]
  transactions Transaction[]
  budgets      Budget[]

  @@index([slug])
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

model User {
  id             String        @id @default(cuid())
  name           String?
  email          String        @unique
  emailVerified  DateTime?
  hashedPassword String?
  image          String?
  role           Role          @default(MEMBER)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  authAccounts AuthAccount[]
  sessions     Session[]
  transactions Transaction[]

  @@index([organizationId])
  @@index([email])
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model AuthAccount {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Account {
  id             String      @id @default(cuid())
  name           String
  type           AccountType
  currency       String      @default("COP")
  initialBalance Decimal     @default(0) @db.Decimal(12, 2)
  currentBalance Decimal     @default(0) @db.Decimal(12, 2)
  color          String      @default("#6366f1")
  icon           String      @default("wallet")
  isActive       Boolean     @default(true)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  transactions Transaction[]

  @@index([organizationId])
}

enum AccountType {
  CASH
  BANK
  CREDIT_CARD
  SAVINGS
  INVESTMENT
  OTHER
}

model Category {
  id             String          @id @default(cuid())
  name           String
  icon           String
  color          String
  type           TransactionType
  isDefault      Boolean         @default(false)
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  transactions Transaction[]
  budgets      Budget[]

  @@unique([name, organizationId])
  @@index([organizationId])
}

model Transaction {
  id             String          @id @default(cuid())
  type           TransactionType
  amount         Decimal         @db.Decimal(12, 2)
  description    String
  notes          String?
  date           DateTime
  isPersonal     Boolean         @default(true)
  receiptUrl     String?
  categoryId     String
  category       Category        @relation(fields: [categoryId], references: [id])
  accountId      String
  account        Account         @relation(fields: [accountId], references: [id])
  userId         String
  user           User            @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deletedAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([organizationId, date])
  @@index([organizationId, categoryId])
  @@index([organizationId, accountId])
  @@index([organizationId, type])
  @@index([userId])
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

model Budget {
  id             String       @id @default(cuid())
  amount         Decimal      @db.Decimal(12, 2)
  spent          Decimal      @default(0) @db.Decimal(12, 2)
  month          Int
  year           Int
  categoryId     String
  category       Category     @relation(fields: [categoryId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([categoryId, month, year, organizationId])
  @@index([organizationId, month, year])
}

model InviteToken {
  id             String       @id @default(cuid())
  email          String
  token          String       @unique
  role           Role         @default(MEMBER)
  organizationId String
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([token])
  @@index([organizationId])
}
